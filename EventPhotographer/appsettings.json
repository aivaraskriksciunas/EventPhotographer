{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ClientUrl": "http://localhost:5173",
  "Authentication": {
    "Cookie": {
      "ExpirationInMinutes": 60
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=eventphotographer_db;Username=admin;Password=admin",
    "RabbitMq": "amqp://rabbit:rabbit-admin@rabbitmq:5672"
  },
  "ShareableLink": {
    "AllowedCodeChars": "0123456789"
  },
  "ObjectStorage": {
    "ServiceURL": "http://minio:9000",
    "ForcePathStyle": true,
    "AccessKey": "admin",
    "Password": "minioadmin123",
    "BucketName": "event-photographer"
  },
  "Sentry": {
    "Dsn": "https://examplePublicKey@o0.ingest.sentry.io/0",
    "SendDefaultPii": true,
    "MaxRequestBodySize": "Always",
    "MinimumBreadcrumbLevel": "Debug",
    "MinimumEventLevel": "Warning",
    "AttachStackTrace": true,
    "Debug": true,
    "DiagnosticLevel": "Error"
  },
  "WhatsApp": {
    "VerificationToken": "token",
    "SecretKey": "SecretKey"
  }
}
